job	numdiff
units	metal
atom	name type mass charge posn vel force

type	Na # 1
type	Cl # 2

format	xyz
fstruc	NaCl_rs_rand.xyz

engine  1
int	quickmin 1.0e-3
#int	cg 1.0e-3
#int	fire dt     dtmin  dtmax  fdtd fdti alpha falpha ndelay nmax
#int	fire 1.0e-1 1.0e-4 1.0e1 0.5  1.1  0.25  0.99   5     10
#ftol    1.0e-3

calc	grho_long 8.0 1.0e-4 arithmetic
coeff	grho_long 1 0.71
coeff	grho_long 2 1.02

nstep	1
nprint	1
nwrite	1

